{
  "name": "grimoire-assignment-2",
  "version": "2.0.0",
  "description": "React single-page prompt vault with Express, Firebase Authentication, and Cloud Firestore.",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"cross-env PORT=4000 nodemon server.js\" \"vite --host 0.0.0.0\"",
    "server": "cross-env PORT=4000 nodemon server.js",
    "build": "vite build",
    "start": "cross-env PORT=4000 node server.js",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.4",
    "vite": "^7.3.0"
  }
}
